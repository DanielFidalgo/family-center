  "query": "SELECT id, household_id, person_id, title, description, color, start_at, end_at, is_all_day, created_at, updated_at\n               FROM family_center.local_activities\n               WHERE household_id = $1\n                 AND (\n                   (start_at IS NOT NULL AND start_at >= $2 AND start_at < $3)\n                   OR start_at IS NULL\n                 )",
